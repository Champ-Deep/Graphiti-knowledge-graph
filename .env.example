# Graphiti Knowledge Graph Configuration
# ========================================
# Copy this file to .env and fill in your values
#
# For Railway deployment, set these as environment variables in the Railway dashboard.

# ===========================================
# API Server Configuration
# ===========================================
API_HOST=0.0.0.0
API_PORT=8080

# API Key for authentication (REQUIRED in production)
# Generate a secure key: openssl rand -hex 32
# This key must match the X-API-Key header sent by n8n
# Leave empty for local development (auth disabled - NOT recommended)
API_KEY=your-secure-api-key-here

# ===========================================
# LLM Configuration (OpenRouter recommended)
# ===========================================
# Get your API key from: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Recommended models via OpenRouter:
# - anthropic/claude-sonnet-4 (best for extraction, ~$3/1M tokens)
# - openai/gpt-4o-mini (fast and cheap, ~$0.15/1M tokens)
# - google/gemini-2.0-flash-exp (good balance)
MODEL_NAME=openai/gpt-4o-mini

# ===========================================
# Neo4j Database
# ===========================================
# For local Docker: bolt://localhost:7687
# For Railway Neo4j: bolt://neo4j.railway.internal:7687 (use private networking)
# For Railway Aura: neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ===========================================
# Google Workspace (Gmail) - Optional
# ===========================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=

# ===========================================
# Microsoft 365 (Outlook) - Optional
# ===========================================
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_USER_EMAIL=

# ===========================================
# Team Configuration
# ===========================================
# Your company's email domains (comma-separated)
# Used to identify internal team members vs external contacts
TEAM_DOMAINS=yourcompany.com,lakeb2b.com
