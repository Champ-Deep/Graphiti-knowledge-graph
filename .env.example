# Email Knowledge Graph Configuration
# =====================================
# Copy this file to .env and fill in your values

# OpenRouter API (OpenAI-compatible endpoint)
# Get your API key from: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Recommended models via OpenRouter:
# - anthropic/claude-sonnet-4 (best for extraction)
# - openai/gpt-4o-mini (fast and cheap)
# - google/gemini-2.0-flash-exp (good balance)
MODEL_NAME=anthropic/claude-sonnet-4

# Neo4j Database
# Default credentials for local Docker instance
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# Google Workspace (Gmail)
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=
GOOGLE_USER_EMAIL=

# Microsoft 365 (Outlook) - Optional
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_USER_EMAIL=

# Your company's email domains (comma-separated)
# Used to identify internal team members vs external contacts
TEAM_DOMAINS=yourcompany.com

# WhatsApp Assistant Integration (Optional)
# Endpoint where the CEO WhatsApp assistant can query this service
API_HOST=0.0.0.0
API_PORT=8080

# =============================================================================
# NEW: Sales Intelligence Platform - Optional Integrations
# =============================================================================

# Enrichment APIs (Optional - for firmographic/technographic data)
# -----------------------------------------------------------------

# Clearbit - Firmographics + Technographics
# Get API key from: https://dashboard.clearbit.com/api
CLEARBIT_API_KEY=

# BuiltWith - Technology Stack Detection
# Get API key from: https://api.builtwith.com/
BUILTWITH_API_KEY=

# People Data Labs - Contact Enrichment
# Get API key from: https://www.peopledatalabs.com/
PDL_API_KEY=

# Web Analytics (Optional - for website visitor tracking)
# ---------------------------------------------------------

# Google Analytics 4
# Property ID from GA4 dashboard
GA4_PROPERTY_ID=
GA4_CREDENTIALS_PATH=credentials/ga4_credentials.json

# Segment CDP
SEGMENT_API_KEY=
SEGMENT_WORKSPACE=

# Social Media (Optional - for social engagement tracking)
# ----------------------------------------------------------

# LinkedIn
# Get access token from: https://www.linkedin.com/developers/
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=

# Twitter/X
# Get bearer token from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=
TWITTER_ACCOUNT_ID=

# Outreach Personalization
# -------------------------

# LLM Model for outreach generation (defaults to gpt-4)
# Options: gpt-4, gpt-4-turbo, gpt-3.5-turbo, claude-sonnet-4
OUTREACH_MODEL=gpt-4

# =============================================================================
# Quick Setup Guide
# =============================================================================
#
# MINIMAL SETUP (Email only - already working):
#   1. Set NEO4J_PASSWORD
#   2. Set OPENAI_API_KEY
#   3. Configure Gmail OAuth (see setup_gmail_oauth.py)
#
# SALES INTELLIGENCE (Recommended):
#   1. Minimal setup above
#   2. Add at least one enrichment API (Clearbit recommended)
#   3. Optionally add web analytics (GA4)
#   4. Optionally add social media (LinkedIn)
#
# See SALES_INTEGRATION_GUIDE.md for detailed setup instructions
#
